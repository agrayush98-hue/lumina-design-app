rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User doc + all subcollections (profile, fixtures, subscription, billingHistory)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Projects — create requires auth + userId matches; read/update/delete requires ownership
    match /projects/{projectId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // Shared projects readable by any authenticated user
      allow read: if request.auth != null && resource.data.isShared == true;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
