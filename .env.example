# Copy this file to .env and fill in your Firebase config values
# Get these from: Firebase Console → Project Settings → Your Apps → SDK setup

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=lumina-design-adc74.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=lumina-design-adc74
VITE_FIREBASE_STORAGE_BUCKET=lumina-design-adc74.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Cloudflare Worker URL for AI recommender (safe to expose — it's just a URL, not a secret)
# Deploy: cd workers/ai-recommender && npx wrangler deploy
# Then set the secret: npx wrangler secret put ANTHROPIC_API_KEY
VITE_AI_WORKER_URL=https://lumina-ai-recommender.your-subdomain.workers.dev

# Razorpay (frontend key ID only — secret stays server-side)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here
