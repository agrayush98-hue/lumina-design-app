# ── CLIENT-SIDE (VITE_ prefix — bundled into frontend) ───────────────────────
# Get Firebase values from: Firebase Console → Project Settings → Your Apps → SDK setup

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=lumina-design-adc74.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=lumina-design-adc74
VITE_FIREBASE_STORAGE_BUCKET=lumina-design-adc74.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Cloudflare Worker URL for AI recommender (safe to expose — it's just a URL)
# Deploy: cd workers/ai-recommender && npx wrangler deploy
# Then set the secret: npx wrangler secret put ANTHROPIC_API_KEY
VITE_AI_WORKER_URL=https://lumina-ai-recommender.your-subdomain.workers.dev

# Razorpay frontend key (public key ID only — secret stays server-side)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# ── SERVER-SIDE (Vercel environment variables — never committed) ──────────────

# Firebase Admin SDK — paste the full service account JSON as a single-line string
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Razorpay server-side keys
# Get from: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Get from: Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Resend.com — transactional email (welcome, trial reminders, subscription alerts)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Zoho SMTP — support/info email addresses
# Get from: Zoho Mail → Settings → Mail Accounts → SMTP
ZOHO_SMTP_PASS=your_zoho_smtp_password
ZOHO_SMTP_PASS_INFO=your_zoho_info_smtp_password       # optional: info@lightillumina.com
ZOHO_SMTP_PASS_BUSINESS=your_zoho_business_smtp_password  # optional: business@lightillumina.com

# Firestore backup cron — set a random secret and add to Vercel + vercel.json cron header
CRON_SECRET=your_random_cron_secret_here
# GCS bucket for Firestore backups (optional — leave blank to skip backups)
GCS_BACKUP_BUCKET=your-gcs-bucket-name
